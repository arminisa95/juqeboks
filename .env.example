# JUKE Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_secure_jwt_secret_here_min_32_chars

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=juke_db
DB_USER=juke_user
DB_PASSWORD=your_database_password
DB_SSL=false

# S3/R2 Storage (Optional - for cloud file storage)
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Stripe Payment Integration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_USER_PRICE_ID=
STRIPE_GROUP_PRICE_ID=

# App Base URL (used for Stripe redirect and email links)
APP_BASE_URL=http://localhost:3000

# Email / SMTP Configuration (Optional - if not set, verification code is logged)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@juqeboks.de
